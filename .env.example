# Claudio DJ 配置文件
# 复制此文件为 .env 并填入真实的 Key

# ─── AI ──────────────────────────────────────────

# Anthropic API Key（兼容 DeepSeek / 任何 Anthropic 兼容 API）
# 支持两种方式提供 Key：
#   1. ANTHROPIC_AUTH_TOKEN — 优先级更高（可设为系统环境变量）
#   2. ANTHROPIC_API_KEY    — 写在 .env 文件中
ANTHROPIC_AUTH_TOKEN=your-api-key-here

# API 端点
# - 官方 Anthropic API: 不设置（默认）
# - DeepSeek 兼容接口: https://api.deepseek.com/anthropic
# - 其他兼容接口: 填写对应的 base URL
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# 模型名称
# - DeepSeek: deepseek-v4-pro[1m]（推理模型，需 max_tokens ≥ 8192）
# - Anthropic 官方: claude-sonnet-4-6 / claude-opus-4-8
ANTHROPIC_MODEL=deepseek-v4-pro[1m]

# ─── 网易云音乐 ──────────────────────────────────

# 网易云音乐 Cookie（可选，用于获取 VIP 歌曲和个性化推荐）
# 登录 https://music.163.com 后从浏览器获取
NETEASE_COOKIE=

# ─── 语音合成 TTS ───────────────────────────────

# GPT-SoVITS API 地址（本地声音克隆服务）
# 安装: https://github.com/RVC-Boss/GPT-SoVITS
# 启动: python api_v2.py（默认端口 9880）
TTS_API_URL=http://127.0.0.1:9880

# 参考音频路径（用于声音克隆的声源）
# 提供目标人物的 1-5 分钟干净语音文件
TTS_REF_AUDIO=

# 参考音频对应的文本内容
TTS_PROMPT_TEXT=

# 参考音频语言（默认 zh）
TTS_PROMPT_LANG=zh

# ─── 天气 ────────────────────────────────────────

# 天气城市（可选，默认 Beijing）
# WEATHER_CITY=Beijing

# OpenWeatherMap API Key（可选，有 Key 时优先使用）
# 免费注册: https://openweathermap.org/api
# OWM_API_KEY=
